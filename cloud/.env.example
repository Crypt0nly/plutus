###############################################################################
# Plutus Cloud – Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control!
###############################################################################

# ─── General ────────────────────────────────────────────────────────────────
# Application environment: development | staging | production
APP_ENV=development

# Enable debug mode (disable in production!)
DEBUG=true

# Secret key for signing tokens/sessions (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=plutus
POSTGRES_PASSWORD=plutus
POSTGRES_DB=plutus
POSTGRES_PORT=5432

# Full connection string (used by backend; overridden in docker-compose)
DATABASE_URL=postgresql+asyncpg://plutus:plutus@localhost:5432/plutus

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# Full connection string (used by backend; overridden in docker-compose)
REDIS_URL=redis://localhost:6379/0

# ─── Clerk Authentication ──────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Frontend needs the publishable key prefixed with VITE_
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ─── Frontend ───────────────────────────────────────────────────────────────
# API base URL the frontend uses to reach the backend
VITE_API_BASE_URL=http://localhost:8000

# Public base URL of the backend as seen from the internet.
# ⚠️  Set this to your real domain in production — it is embedded in sync tokens
# so the local Plutus client knows which server to connect to.
# Example: https://api.plutus.yourdomain.com
SERVER_BASE_URL=http://localhost:8000

# Port the frontend dev server listens on
FRONTEND_PORT=3000

# Port the backend listens on
BACKEND_PORT=8000

# ─── LLM Providers ─────────────────────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini) – optional
GOOGLE_API_KEY=

# ─── E2B Cloud Sandbox ──────────────────────────────────────────────────────
# Required for the cloud sandbox fallback (used when the local bridge is offline).
# Get your key at https://e2b.dev/dashboard
E2B_API_KEY=

# ─── Bridge Service (optional, for desktop ↔ cloud sync) ───────────────────
# BRIDGE_PORT=8080
# BRIDGE_MODE=relay
# BRIDGE_SECRET=change-me-bridge-secret

# ─── Celery / Task Queue (optional) ────────────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Email / SMTP (optional, for notifications) ────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@plutus.dev

# ─── Sentry Error Tracking (optional) ──────────────────────────────────────
# SENTRY_DSN=

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
